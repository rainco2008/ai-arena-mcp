{
  "name": "contentpilot",
  "private": true,
  "description": "Local development helpers for ContentPilot resource acquisition and workflow automation.",
  "integrations": {
    "n8nWorkflows": "https://github.com/Zie619/n8n-workflows",
    "markitdown": "https://github.com/microsoft/markitdown"
  },
  "scripts": {
    "api:dev": "python -m gemini_search --host 127.0.0.1 --port 8081",
    "web:dev": "next dev apps/web --port 8080",
    "web:build": "next build apps/web",
    "web:start": "next start apps/web --port 8080",
    "db:generate": "drizzle-kit generate --config apps/web/drizzle.config.ts",
    "db:push": "drizzle-kit push --config apps/web/drizzle.config.ts",
    "n8n": "n8n start",
    "n8n:index-templates": ".\\scripts\\index_n8n_workflow_templates.cmd",
    "n8n:sync-templates": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\sync_n8n_workflows_vendor.ps1"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.23.0",
    "n8n": "2.28.6",
    "next": "^16.2.10",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "n8n-mcp": "^2.63.0",
    "typescript": "^6.0.3"
  }
}
