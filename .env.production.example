# Domain that points to the VPS public IP.
DOMAIN=search.example.com

# Email used by Caddy / Let's Encrypt for certificate notifications.
ACME_EMAIL=admin@example.com

# Optional admin token for the web console and management APIs.
# deploy_ubuntu_docker.sh auto-generates one when this is empty.
ADMIN_TOKEN=

# Optional Chrome proxy, for example: socks5://127.0.0.1:7897
GEMINI_SEARCH_PROXY_SERVER=

# Backend: playwright or cloakbrowser.
GEMINI_SEARCH_BROWSER_BACKEND=playwright

# Search provider: google_ai_mode, gemini_grounding, brave, or tavily.
# google_ai_mode uses the existing browser scraping fallback.
GEMINI_SEARCH_PROVIDER=google_ai_mode

# Required only when GEMINI_SEARCH_PROVIDER=gemini_grounding.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Required only when GEMINI_SEARCH_PROVIDER=brave.
BRAVE_API_KEY=

# Required only when GEMINI_SEARCH_PROVIDER=tavily.
TAVILY_API_KEY=
TAVILY_SEARCH_DEPTH=basic

# Google regional origin used by the browser session.
GEMINI_SEARCH_GOOGLE_BASE_URL=https://www.google.co.uk

# Natural warmup query typed into Google before AI Mode requests.
GEMINI_SEARCH_WARMUP_QUERY=latest UK technology news and weather in London this week

# Optional profile rotation interval in seconds.
# 0 disables rotation. Example: 86400 rotates once per day.
GEMINI_SEARCH_PROFILE_ROTATION_SECONDS=0
